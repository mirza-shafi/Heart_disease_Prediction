# App
PROJECT_NAME="Heart Disease Prediction API"
VERSION="1.0.0"

# Database (PostgreSQL)
DATABASE_URL="postgresql://heart_user:heart_password@db:5432/heart_db"

# Redis
REDIS_URL="redis://redis:6379/0"

# Celery
CELERY_BROKER_URL="redis://redis:6379/1"
CELERY_RESULT_BACKEND="redis://redis:6379/2"

# Security (Change this in production!)
SECRET_KEY="a_very_secret_key_for_jwt_tokens_please_change_me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"
